APP_ENV=development
HTTP_ADDR=:8080
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/moodlepilot?sslmode=disable
SITE_DB_ADMIN_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@moodlepilot.local
SESSION_COOKIE_NAME=moodlepilot_session
SESSION_TTL_HOURS=24
REMEMBER_ME_TTL_HOURS=720
PASSWORD_RESET_TTL_MINUTES=30
VERIFY_EMAIL_TTL_MINUTES=15
PROVISIONING_RUNTIME_MODE=docker_local
SITE_BASE_DOMAIN=lvh.me
SITE_URL_SCHEME=http
DOCKER_PROXY_NETWORK=moodlepilot-proxy
TRAEFIK_API_URL=http://127.0.0.1:8088
MOODLE_IMAGE_REPOSITORY=local/moodle-app
MOODLE_IMAGE_TAG=5.1-local
SITE_RUNTIME_SECRET=local-runtime-secret
RUN_MIGRATIONS=true
SEED_PLAYWRIGHT_USER=true
PLAYWRIGHT_SEED_NAME=Playwright Test
PLAYWRIGHT_SEED_EMAIL=playwright@example.com
PLAYWRIGHT_SEED_PASSWORD=Playwright123!
PLAYWRIGHT_SEED_COMPANY=Playwright QA
PLAYWRIGHT_SEED_ORGANIZATION=Playwright Testing
USAGE_METER_SCHEDULE=@every 5m
HOST_STORAGE_BUDGET_BYTES=536870912000
HOST_CPU_MILLICORES_BUDGET=8000
HOST_MEMORY_MIB_BUDGET=12288
DOCKER_WEB_PIDS_LIMIT=256
DOCKER_CRON_PIDS_LIMIT=128